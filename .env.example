# ─── Supabase (required for auth + Phase 2 dashboard) ──────────────────
# Get these from https://supabase.com/dashboard/project/dyfeolrotkjmeuknbx/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Set to "true" to drive the dashboard from lib/mock-data.ts (no real
# queries hit Supabase). Useful while running the Phase-1 demo or tests.
USE_MOCK_DATA=true

# ─── Meta Marketing API (required for Phase 3 Connect + Sync) ──────────
# Step 1: register a Meta app at https://developers.facebook.com
# Step 2: add "Marketing API" as a product on the app dashboard
# Step 3: under Settings → Basic, copy "App ID" → META_APP_ID
# Step 4: under Settings → Basic → "Show" → copy "App Secret" → META_APP_SECRET
# Step 5: add http://localhost:3000/api/auth/meta/callback as a "Valid
#         OAuth Redirect URI" (in the app's "Facebook Login" → Settings
#         → Use Strict Mode for Redirect URIs = ON if you want to keep
#         that URL strict in dev).
# Step 6: choose your API version (default is v18.0 if unset).
META_APP_ID=
META_APP_SECRET=
# Default in dev: http://localhost:3000/api/auth/meta/callback
# Production: https://your-domain.com/api/auth/meta/callback
META_REDIRECT_URI=
# Optional override; default is v18.0.
# META_API_VERSION=v18.0
