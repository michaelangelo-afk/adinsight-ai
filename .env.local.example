# ==============================================================================
# GrowthAds — Environment Variables
# Copy this file to .env.local and fill in your values.
# ==============================================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Meta Ads API (Phase 3) ---
META_APP_ID=
META_APP_SECRET=
# IMPORTANT: must EXACTLY match what you've whitelisted as a Valid OAuth
# Redirect URI on your Meta app dashboard (developers.facebook.com →
# Facebook Login → Settings). The route handler lives at this path:
#   app/api/auth/meta/callback/route.ts
# Local dev:  http://localhost:3000/api/auth/meta/callback
# Production: https://your-domain.com/api/auth/meta/callback
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback

# --- Paystack (Phase 5) ---
PAYSTACK_PUBLIC_KEY=pk_test_
PAYSTACK_SECRET_KEY=sk_test_

# --- AI Engine (Phase 4 — mock for now) ---
AI_ENGINE_URL=
AI_ENGINE_API_KEY=

# --- Feature Flags ---
USE_MOCK_DATA=true
